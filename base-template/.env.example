# ─────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────
APP_ENV=local                        # local | acceptance | production
NODE_ENV=development

# ─────────────────────────────────────────────
# CAPE (Headless CMS)
# ─────────────────────────────────────────────
NEXT_PUBLIC_CAPE_URL=https://storage.bycape.io
NEXT_PUBLIC_CAPE_CAMPAIGN_ID=        # Numeric campaign ID from CAPE dashboard
NEXT_PUBLIC_CAPE_MARKET=NL           # Market code: NL | BE | FR | DE …
NEXT_PUBLIC_CAPE_LANGUAGE=NL         # Default language fallback

# ─────────────────────────────────────────────
# Backend API
# ─────────────────────────────────────────────
API_URL=http://localhost:3001        # Server-side only (never NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:3001  # Client-side if needed

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
SERVER_SECRET=changeme              # Used to sign/verify server tokens

# ─────────────────────────────────────────────
# GCP Logging (optional — remove if not using GCP)
# ─────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_LOG_NAME=campaign-template
GCP_ENABLE=false                    # Set true in acceptance/production
LOG_LEVEL=debug                     # error | warn | info | http | debug

# ─────────────────────────────────────────────
# Unity WebGL (module: unity)
# ─────────────────────────────────────────────
# NEXT_PUBLIC_UNITY_BASE_URL=https://cdn.example.com/games/my-game
# NEXT_PUBLIC_UNITY_GAME_NAME=MyGame
# NEXT_PUBLIC_UNITY_VERSION=1.0.0
# NEXT_PUBLIC_UNITY_COMPRESSION=gzip    # gzip | br | none
# NEXT_PUBLIC_UNITY_DESKTOP_DPR=1
# NEXT_PUBLIC_UNITY_MOBILE_DPR=1

# ─────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_DEVTOOLS=true    # Force devtools regardless of APP_ENV
