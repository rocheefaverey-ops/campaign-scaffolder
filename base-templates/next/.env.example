# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
APP_ENV=local                         # local | acceptance | production
NEXT_PUBLIC_ENV=local                 # local | acceptance | production

# ─────────────────────────────────────────────
# CAPE (Headless CMS)
# ─────────────────────────────────────────────
NEXT_PUBLIC_CAPE_URL=https://storage-acceptance.bycape.io/account-60/fixed
NEXT_PUBLIC_CAPE_DEFAULT_ID={{CAPE_ID}}
NEXT_PUBLIC_CAPE_DEFAULT_MARKET={{MARKET}}
NEXT_PUBLIC_CAPE_LANGUAGE=nl

# ─────────────────────────────────────────────
# Backend API
# ─────────────────────────────────────────────
API_URL=https://wave-{{PROJECT_NAME}}-api-acc.lwdev.nl

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
SERVER_SECRET=changeme

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_TO_FILE=0
LOG_TO_GCP=0
LOG_STRUCTURED_CONSOLE=0
LOG_LEVEL=info
GCP_LOG_PROJECT=
GCP_LOG_KEYFILE=
GCP_REPORTING_NAME=

# ─────────────────────────────────────────────
# Mock / Dev
# ─────────────────────────────────────────────
# Set CAPE_MOCK=true to serve public/mock-cape.json instead of hitting the CDN.
# Workflow:
#   1. npm run cape:fetch-mock   ← fetches real campaign data once
#   2. Set CAPE_MOCK=true
#   3. npm run dev:mock          ← runs without CDN
CAPE_MOCK=false

# ─────────────────────────────────────────────
# Unity WebGL (module: unity)
# ─────────────────────────────────────────────
# NEXT_PUBLIC_UNITY_BASE_URL=https://lw-wave-{{PROJECT_NAME}}-unity-acc.lwcf5.nl
# NEXT_PUBLIC_UNITY_GAME_NAME=Game
# NEXT_PUBLIC_UNITY_VERSION=V1
# NEXT_PUBLIC_UNITY_COMPRESSION=br
# NEXT_PUBLIC_UNITY_MIN_DPR=1
# NEXT_PUBLIC_UNITY_MAX_DPR=1.5
