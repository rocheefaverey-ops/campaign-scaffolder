{
  "id": "unity",
  "name": "Unity WebGL Game",
  "description": "Mount Unity WebGL games with automatic boot sequence and event handling",
  "version": "1.0.0",
  "order": 10,
  "engine": "unity",

  "files": [
    {
      "src": "components/UnityCanvas.tsx",
      "dest": "components/_modules/unity/UnityCanvas.tsx",
      "type": "component"
    },
    {
      "src": "components/useUnityBridge.ts",
      "dest": "components/_modules/unity/useUnityBridge.ts",
      "type": "component"
    },
    {
      "src": "lib/LivewallBridge.jslib",
      "dest": "public/LivewallBridge.jslib",
      "type": "asset"
    }
  ],

  "packages": [],

  "envVars": [],

  "cspPatch": {
    "script-src": ["https://*.lwcf.nl", "https://*.lwcf5.nl", "https://lw-*.lwdev.nl"],
    "frame-src": ["'self'"]
  },

  "notes": [
    "Unity WebGL builds must include LivewallBridge.jslib in Assets/Plugins/WebGL/",
    "Environment variables required: NEXT_PUBLIC_UNITY_BASE_URL, NEXT_PUBLIC_UNITY_GAME_NAME",
    "Unity game must emit events via SendEventToReact() from LivewallBridge",
    "See /public/LivewallBridge.jslib for C# integration examples"
  ]
}
